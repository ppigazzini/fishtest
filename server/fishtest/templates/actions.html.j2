{% extends "base.html.j2" %}

{% block title %}Events Log | Stockfish Testing{% endblock %}

{% block body %}
{% set action_filter = action_param if action_param is defined else (filters.action if filters is defined and filters.action is defined else "") %}
{% set username_filter = username_param if username_param is defined else (filters.username if filters is defined and filters.username is defined else "") %}
{% set text_filter = text_param if text_param is defined else (filters.text if filters is defined and filters.text is defined else "") %}
{% set run_id_filter = run_id_filter if run_id_filter is defined else (filters.run_id if filters is defined and filters.run_id is defined else "") %}
{% set max_count = max_count if max_count is defined else none %}
{% set sort = sort if sort is defined else "time" %}
{% set order = order if order is defined else "desc" %}
<div id="actions-page">
  <h2>Events Log</h2>

  <form
    id="actions-filters"
    class="row g-3 mb-3 align-items-end"
    method="get"
    action="/actions"
    role="search"
    hx-get="/actions"
    hx-target="#actions-content"
    hx-push-url="true"
    hx-swap="innerHTML"
    hx-trigger="submit, input changed delay:{{ htmx.input_changed_delay_ms }}ms from:#actions_user, search from:#actions_user, input changed delay:{{ htmx.input_changed_delay_ms }}ms from:#actions_text, search from:#actions_text, change from:#actions_action"
  >
    {% if run_id_filter %}
      <input type="hidden" name="run_id" value="{{ run_id_filter }}">
    {% endif %}
    {% if max_count is not none %}
      <input type="hidden" name="max_count" value="{{ max_count }}">
    {% endif %}
    <input type="hidden" name="sort" value="{{ sort }}">
    <input type="hidden" name="order" value="{{ order }}">

    <div class="col-12 col-md-auto">
      <label for="actions_action" class="form-label">Show only</label>
      <select id="actions_action" class="form-select" name="action">
        {% for option in action_filter_options %}
          <option value="{{ option.value }}" {{ 'selected' if option.selected else '' }}{% if option.class_name %} class="{{ option.class_name }}"{% endif %}>
            {{ option.label }}
          </option>
        {% endfor %}
      </select>
    </div>

    <div class="col-12 col-md-auto">
      <label for="actions_user" class="form-label">From user</label>
      <input
        id="actions_user"
        class="form-control"
        placeholder="Search by username"
        type="search"
        name="user"
        value="{{ username_filter }}"
      >
    </div>

    <div class="col-12 col-md-auto">
      <label for="actions_text" class="form-label">Free text search</label>
      <button
        type="button"
        class="btn btn-link btn-sm p-0 align-baseline"
        aria-label="Show free text search help"
        data-bs-toggle="modal"
        data-bs-target="#autoselect-modal"
      >
        <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
      </button>
      <div
        class="modal fade"
        id="autoselect-modal"
        tabindex="-1"
        aria-hidden="true"
      >
        <div class="modal-dialog modal-dialog-scrollable">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title">Free text search information</h5>
              <button
                type="button"
                class="btn-close"
                data-bs-dismiss="modal"
                aria-label="Close"
              ></button>
            </div>
            <div class="modal-body text-break">
              This performs a case-insensitive
              <a
                href="https://www.mongodb.com/docs/manual/reference/operator/query/text/#mongodb-query-op.-text"
                target="_blank" rel="noopener noreferrer"
              >MongoDB <i>$text</i> search</a>
              on event name, user name, worker name, target user, network name,
              branch name and comment.
              <ul class="mt-2 mb-2">
                <li>Type space-separated words to match any of them.</li>
                <li>Wrap words in straight double quotes to match an exact phrase: <i>&quot;dog cat&quot;</i>.</li>
                <li>Precede a word with a minus sign to exclude it: <i>dog &minus;cat</i>.</li>
                <li>Only full words match. For example, worker name <i>fishtestfan-128cores-abcdefgh-uvwx</i> matches <i>abcdefgh</i> but not <i>abcde</i>.</li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <input
        id="actions_text"
        class="form-control"
        placeholder="Enter some text"
        type="search"
        name="text"
        value="{{ text_filter }}"
      >
    </div>

  </form>

  <div id="actions-content">
    {% include "actions_content_fragment.html.j2" %}
  </div>
</div>
{% endblock %}
